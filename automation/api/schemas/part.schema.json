{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InvenTree Part",
  "description": "Schema for a Part object returned by the InvenTree API (union of list and detail fields)",
  "type": "object",
  "required": [
    "pk",
    "name",
    "category",
    "active",
    "assembly",
    "component",
    "is_template",
    "purchaseable",
    "salable",
    "trackable",
    "virtual"
  ],
  "properties": {
    "pk": {
      "type": "integer",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "maxLength": 250
    },
    "category": {
      "type": ["integer", "null"]
    },
    "category_detail": {
      "type": ["object", "null"],
      "readOnly": true
    },
    "category_name": {
      "type": "string",
      "readOnly": true
    },
    "category_path": {
      "type": "array",
      "readOnly": true,
      "items": {
        "type": "object",
        "properties": {
          "pk": { "type": "integer" },
          "name": { "type": "string" },
          "icon": { "type": "string" }
        }
      }
    },
    "IPN": {
      "type": ["string", "null"]
    },
    "active": {
      "type": "boolean"
    },
    "assembly": {
      "type": "boolean"
    },
    "component": {
      "type": "boolean"
    },
    "is_template": {
      "type": "boolean"
    },
    "purchaseable": {
      "type": "boolean"
    },
    "salable": {
      "type": "boolean"
    },
    "trackable": {
      "type": "boolean"
    },
    "testable": {
      "type": "boolean"
    },
    "virtual": {
      "type": "boolean"
    },
    "locked": {
      "type": "boolean"
    },
    "keywords": {
      "type": ["string", "null"]
    },
    "link": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "minimum_stock": {
      "type": "number"
    },
    "default_expiry": {
      "type": "integer"
    },
    "units": {
      "type": "string"
    },
    "variant_of": {
      "type": ["integer", "null"]
    },
    "revision": {
      "type": "string"
    },
    "revision_of": {
      "type": ["integer", "null"],
      "readOnly": true
    },
    "revision_count": {
      "type": ["integer", "null"],
      "readOnly": true
    },
    "barcode_hash": {
      "type": "string",
      "readOnly": true
    },
    "creation_date": {
      "type": ["string", "null"],
      "readOnly": true
    },
    "creation_user": {
      "type": ["integer", "null"],
      "readOnly": true
    },
    "default_location": {
      "type": ["integer", "null"]
    },
    "default_location_detail": {
      "type": ["object", "null"],
      "readOnly": true
    },
    "full_name": {
      "type": "string",
      "readOnly": true
    },
    "image": {
      "type": ["string", "null"]
    },
    "thumbnail": {
      "type": "string",
      "readOnly": true
    },
    "parameters": {
      "type": "array",
      "readOnly": true
    },
    "starred": {
      "type": "boolean"
    },
    "pricing_min": {
      "type": ["string", "null"],
      "readOnly": true
    },
    "pricing_max": {
      "type": ["string", "null"],
      "readOnly": true
    },
    "pricing_updated": {
      "type": ["string", "null"],
      "readOnly": true
    },
    "responsible": {
      "type": ["integer", "null"]
    },
    "in_stock": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "total_in_stock": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "external_stock": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "unallocated_stock": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "variant_stock": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "building": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "ordering": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "stock_item_count": {
      "type": ["integer", "null"],
      "readOnly": true
    },
    "allocated_to_build_orders": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "allocated_to_sales_orders": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "required_for_build_orders": {
      "type": ["number", "integer", "null"],
      "readOnly": true
    },
    "required_for_sales_orders": {
      "type": ["number", "integer", "null"],
      "readOnly": true
    },
    "scheduled_to_build": {
      "type": ["number", "null"],
      "readOnly": true
    },
    "category_default_location": {
      "type": ["integer", "null"],
      "readOnly": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "price_breaks": {
      "type": "array",
      "readOnly": true
    }
  },
  "additionalProperties": true
}
