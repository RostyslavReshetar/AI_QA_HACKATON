{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Part",
  "type": "object",
  "required": ["id", "name", "category", "active"],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "description": { "type": ["string", "null"], "maxLength": 250 },
    "category": { "type": ["integer", "null"] },
    "active": { "type": "boolean" },
    "assembly": { "type": "boolean" },
    "component": { "type": "boolean" },
    "purchaseable": { "type": "boolean" },
    "salable": { "type": "boolean" },
    "trackable": { "type": "boolean" },
    "virtual": { "type": "boolean" },
    "is_template": { "type": "boolean" },
    "minimum_stock": { "type": "number", "minimum": 0 },
    "units": { "type": ["string", "null"] },
    "keywords": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "link": { "type": ["string", "null"] },
    "revision": { "type": ["string", "null"] },
    "variant_of": { "type": ["integer", "null"] },
    "revision_of": { "type": ["integer", "null"] },
    "full_name": { "type": "string" },
    "pk": { "type": "integer" }
  },
  "additionalProperties": true
}